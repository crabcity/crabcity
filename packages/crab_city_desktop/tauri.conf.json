{
  "$schema": "https://raw.githubusercontent.com/nickelpack/tauri-v2/refs/heads/dev/crates/tauri-schema-generator/schemas/config.schema.json",
  "productName": "Crab City",
  "version": "0.1.0",
  "identifier": "com.crabcity.desktop",
  "build": {
    "frontendDist": "loading-dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "Crab City",
        "width": 1400,
        "height": 900,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "center": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
